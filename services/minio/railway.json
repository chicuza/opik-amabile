{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "IMAGE",
    "image": "bitnamilegacy/minio:2025.7.23-debian-12-r5"
  },
  "deploy": {
    "healthcheckPath": "/minio/health/live",
    "healthcheckTimeout": 60,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
