# AmabileAI Observability SDK configuration for downstream consumer apps.
# Copy to .env in the consumer project, fill in OPIK_API_KEY after signing up at the UI.
# OPIK_* variable names are the SDK package contract (PyPI: opik) and are kept verbatim.

OPIK_URL_OVERRIDE=https://fabricaai.amabileai.com.br/api
OPIK_API_KEY=
OPIK_WORKSPACE=default
OPIK_PROJECT_NAME=default

# Infra credentials — only set on the operator machine, never in app .env files.
# RAILWAY_TOKEN=
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=a6198bf88ab2f420eb3bcf23c2225a8b
